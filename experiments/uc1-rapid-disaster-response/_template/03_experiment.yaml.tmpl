apiVersion: int.esa.yass/v1
kind: Experiment
metadata:
  name: ${RUN_ID}
  namespace: ${NAMESPACE}
spec:
  # Pinned simulationStartTime so TUS and EDFS runs of the same matrix
  # entry see identical orbital geometry.
  simulationStartTime: "2026-05-16T23:59:00.000Z"
  experimentDefRef: ${RUN_ID}
  layoutDefRef: ${LAYOUT_REF}
  runId: "${RUN_ID}"
  engineContainers:
    - name: engine-${ENGINE}
      image: "${ENGINE_IMAGE}"
      imagePullPolicy: Always
      env:
        - name: GROUND_STATIONS
          value: "*"
${ENGINE_EXTRA_ENV}
  start: true
