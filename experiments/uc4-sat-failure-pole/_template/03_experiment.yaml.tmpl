apiVersion: int.esa.yass/v1
kind: Experiment
metadata:
  name: ${RUN_ID}
  namespace: ${NAMESPACE}
spec:
  # simulationStartTime equals the synthetic `producer` satellite's TLE epoch,
  # so at t=0 the producer is over the SOUTH pole and out of LOS with every
  # ESTRACK station (see tools/make-producer-layouts.py). The UC4 precondition
  # — producer out of LOS at photo time — holds by construction.
  simulationStartTime: "2026-05-16T23:59:00.000Z"
  experimentDefRef: ${RUN_ID}
  layoutDefRef: ${LAYOUT_REF}
  runId: "${RUN_ID}"
${ENGINE_CONTAINERS}
  start: true
